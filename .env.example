# Public site URL (canonical, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://majidmemari.com

# Try My AI — public URLs for linked apps in the Work section
NEXT_PUBLIC_AI_CPA_URL=
NEXT_PUBLIC_AI_TA_URL=

# OpenAI — required for /api/chat (site assistant) and contact-form classification
OPENAI_API_KEY=
# Optional override (default: gpt-5.4-mini)
OPENAI_MODEL=gpt-5.4-mini
# Optional model for contact classification (default: gpt-4o-mini)
CONTACT_CLASSIFY_MODEL=gpt-4o-mini

# Email — optional; without RESEND_API_KEY, contact form logs server-side only
RESEND_API_KEY=
# Must be a verified sender in Resend, e.g. Majid Memari <hello@majidmemari.com>
RESEND_FROM_EMAIL=
CONTACT_TO_EMAIL=memari.majid@hotmail.com
